# Copy to .env and fill in real values. .env is gitignored.

# --- LLM providers ---
# Used when MODEL_PROVIDER = "openai" in main.py
OPENAI_API_KEY=sk-your-openai-key-here
# Used when MODEL_PROVIDER = "openrouter"
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# --- Postgres / pgvector (semantic memory) ---
# Use localhost when running the backend natively (or for the smoke test).
# docker-compose overrides this to the 'postgres' service name automatically.
DATABASE_URL=postgresql://bd42:bd42@localhost:5432/bd42

# --- Redis (short-term memory) ---
# Optional — defaults to localhost:6379 if unset. docker-compose overrides
# REDIS_HOST to the 'redis' service name automatically.
REDIS_HOST=localhost
REDIS_PORT=6379
